# =============================================================================
# OpenFMR Terminology Service (TS) Module - Environment Variables
# =============================================================================
# Copy this file to .env and customise the values for your environment.
#
#   cp .env.example .env
#
# SECURITY: Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL Configuration
# -----------------------------------------------------------------------------
# Credentials and database name for the TS-dedicated PostgreSQL instance.
TS_POSTGRES_DB=hapi_ts
TS_POSTGRES_USER=hapi_ts_user
TS_POSTGRES_PASSWORD=change_me_to_a_strong_password

# -----------------------------------------------------------------------------
# FHIR Server Configuration
# -----------------------------------------------------------------------------
# Host port mapped to the TS FHIR server's internal port 8080.
# This is the port you will use to access the Terminology Server from
# the Docker host (e.g., http://localhost:8084/fhir/metadata).
TS_FHIR_PORT=8084
